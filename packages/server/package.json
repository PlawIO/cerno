{
  "name": "@cernosh/server",
  "version": "0.3.1",
  "description": "Server-side validation pipeline for Cerno CAPTCHA: maze-relative behavioral scoring, PoW verification, JWT tokens, CaptchaStore interface",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/PlawIO/cerno.git",
    "directory": "packages/server"
  },
  "homepage": "https://cerno.sh",
  "keywords": [
    "captcha",
    "behavioral-biometrics",
    "server",
    "validation",
    "jwt",
    "anti-bot"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@cernosh/core": "^0.3.0",
    "@simplewebauthn/server": "^13.2.2",
    "jose": "^6.0.0"
  }
}
