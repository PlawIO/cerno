{
  "name": "@cernosh/react",
  "version": "0.2.0",
  "description": "Drop-in React CAPTCHA component for Cerno: canvas maze renderer, pointer/keyboard collectors, PoW web worker, WebCrypto binding",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/PlawIO/cerno.git",
    "directory": "packages/react"
  },
  "homepage": "https://cerno.sh",
  "keywords": ["captcha", "react", "behavioral-biometrics", "maze", "anti-bot", "ai-detection"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "files": ["dist"],
  "dependencies": {
    "@cernosh/core": "^0.2.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
