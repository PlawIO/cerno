        var ei = 0;
        for (var t = start; t <= end && out.length < 5000; t += INTERVAL) {
          while (ei < events.length - 1 && events[ei + 1].t < t) ei++;
          if (ei >= events.length - 1) { out.push({ t: t, x: events[events.length - 1].x, y: events[events.length - 1].y }); break; }
          var e0 = events[ei], e1 = events[ei + 1];
          var dt = e1.t - e0.t;
          var r = dt === 0 ? 0 : (t - e0.t) / dt;
          out.push({ t: t, x: e0.x + (e1.x - e0.x) * r, y: e0.y + (e1.y - e0.y) * r });
        }
        return out;
      }

      function stdDev(a) {
        if (a.length < 2) return 0;
        var m = 0; for (var i = 0; i < a.length; i++) m += a[i]; m /= a.length;
        var v = 0; for (var j = 0; j < a.length; j++) v += (a[j] - m) * (a[j] - m);
        return Math.sqrt(v / (a.length - 1));
      }

      function shannonEntropy(vals, bins) {
        if (vals.length === 0) return 0;
        var mn = vals[0], mx = vals[0];
        for (var i = 1; i < vals.length; i++) { if (vals[i] < mn) mn = vals[i]; if (vals[i] > mx) mx = vals[i]; }
        var rng = mx - mn;
        if (rng === 0) return 0;
        var b = new Array(bins).fill(0);
        for (var j = 0; j < vals.length; j++) b[Math.min(Math.floor((vals[j] - mn) / rng * bins), bins - 1)]++;
        var ent = 0;
        for (var k = 0; k < bins; k++) { if (b[k] === 0) continue; var p = b[k] / vals.length; ent -= p * Math.log2(p); }
        return ent;
      }

      function extractFeatures(rawEvents) {
        if (rawEvents.length < 2) return null;
        var sampled = resample60Hz(rawEvents);
        if (sampled.length < 2) return null;

        var velocities = [], totalPath = 0;
        for (var i = 1; i < sampled.length; i++) {
          var dx = sampled[i].x - sampled[i - 1].x, dy = sampled[i].y - sampled[i - 1].y;
          var dt = sampled[i].t - sampled[i - 1].t;
          var dist = Math.sqrt(dx * dx + dy * dy);
          totalPath += dist;
          velocities.push(dt > 0 ? dist / dt : 0);
        }

        var euclid = Math.sqrt(
          Math.pow(sampled[sampled.length - 1].x - sampled[0].x, 2) +
          Math.pow(sampled[sampled.length - 1].y - sampled[0].y, 2)
        );

        var pauseCount = 0, pauseStart = -1;
        for (var pi = 0; pi < velocities.length; pi++) {
          if (velocities[pi] < 0.0005) {
            if (pauseStart === -1) pauseStart = pi;
          } else {
            if (pauseStart !== -1 && sampled[pi].t - sampled[pauseStart].t >= 100) pauseCount++;
            pauseStart = -1;
          }
        }
        if (pauseStart !== -1 && sampled[sampled.length - 1].t - sampled[pauseStart].t >= 100) pauseCount++;

        var onsetMs = 0;
        for (var oi = 0; oi < velocities.length; oi++) {
          if (velocities[oi] > 0.001) { onsetMs = sampled[oi].t - sampled[0].t; break; }
        }

        var accels = [];
        for (var ai = 1; ai < velocities.length; ai++) {
          var adt = sampled[Math.min(ai + 1, sampled.length - 1)].t - sampled[ai].t;
          accels.push(adt > 0 ? (velocities[ai] - velocities[ai - 1]) / adt : 0);
        }
        var jerks = [];
        for (var ji = 1; ji < accels.length; ji++) {
          var jdt = sampled[Math.min(ji + 2, sampled.length - 1)].t - sampled[Math.min(ji + 1, sampled.length - 1)].t;
          jerks.push(jdt > 0 ? (accels[ji] - accels[ji - 1]) / jdt : 0);
        }

        var angles = [];
        for (var gi = 1; gi < sampled.length; gi++) {
          var gdx = sampled[gi].x - sampled[gi - 1].x, gdy = sampled[gi].y - sampled[gi - 1].y;
          if (Math.abs(gdx) > 1e-8 || Math.abs(gdy) > 1e-8) angles.push(Math.atan2(gdy, gdx));
        }
        var angVels = [];
        for (var vi = 1; vi < angles.length; vi++) {
          var da = angles[vi] - angles[vi - 1];
          while (da > Math.PI) da -= 2 * Math.PI;
          while (da < -Math.PI) da += 2 * Math.PI;
          angVels.push(da);
        }

        var intervals = [];
        for (var ti = 1; ti < rawEvents.length; ti++) {
          var tdt = rawEvents[ti].t - rawEvents[ti - 1].t;
          if (tdt > 0) intervals.push(tdt);
        }
        var timingCv = 0;
        if (intervals.length >= 2) {
          var meanInt = 0; for (var mi2 = 0; mi2 < intervals.length; mi2++) meanInt += intervals[mi2];
          meanInt /= intervals.length;
          if (meanInt > 0) timingCv = stdDev(intervals) / meanInt;
        }

        return {
          velocity_std: stdDev(velocities),
          path_efficiency: totalPath > 0 ? euclid / totalPath : 0,
          pause_count: pauseCount,
          movement_onset_ms: onsetMs,
          jerk_std: stdDev(jerks),
          angular_velocity_entropy: shannonEntropy(angVels, 16),
          timing_cv: timingCv,
          sample_count: sampled.length,
          total_duration_ms: sampled[sampled.length - 1].t - sampled[0].t
        };
      }

      // ── Gaussian scoring (same as @cernosh/server behavioral-scoring) ──
      function gaussScore(val, mean, sd) {
        if (sd === 0) return val === mean ? 1 : 0;
        var z = (val - mean) / sd;
        return Math.exp(-0.5 * Math.pow(z / 3, 2));
      }

      function scoreFeatures(feat) {
        if (!feat) return 0;
        var scores = [
          gaussScore(feat.velocity_std, 0.0004, 0.0003) * 1.0,
          gaussScore(feat.path_efficiency, 0.45, 0.15) * 1.0,
          gaussScore(feat.pause_count, 2, 1.5) * 0.8,
          gaussScore(feat.movement_onset_ms, 800, 400) * 0.6,
          gaussScore(feat.jerk_std, 5e-7, 5e-7) * 1.0,
          gaussScore(feat.angular_velocity_entropy, 2.5, 0.5) * 1.5,
          gaussScore(feat.timing_cv, 0.5, 0.2) * 1.0,
        ];
        var totalWeight = 1.0 + 1.0 + 0.8 + 0.6 + 1.0 + 1.5 + 1.0;
        var sum = 0; for (var i = 0; i < scores.length; i++) sum += scores[i];
        var score = sum / totalWeight;
        if (feat.sample_count < 20) score *= feat.sample_count / 20;
        if (feat.total_duration_ms < 2000) score *= feat.total_duration_ms / 2000;
        return Math.max(0, Math.min(1, score));
      }

      // ── Server state ──
      var challengeData = null;
      var powPromise = null;
      var rawEvents = [];
      var completed = false;

      // ── Interaction ──
      function canvasCoords(e) {
        var rect = canvas.getBoundingClientRect();
        var scaleX = logW / rect.width;
        var scaleY = logH / rect.height;
        return { px: (e.clientX - rect.left) * scaleX, py: (e.clientY - rect.top) * scaleY };
      }

      function ptrType(e) {
        var pt = e.pointerType;
        if (pt === 'mouse' || pt === 'touch' || pt === 'pen') return pt;
        return 'mouse';
      }

      canvas.addEventListener('pointerdown', function(e) {
        if (completed || !maze) return;
        var coords = canvasCoords(e);
        var cell = pxToCell(coords.px, coords.py);
        if (!cell || cell.x !== maze.start.x || cell.y !== maze.start.y) return;

        canvas.setPointerCapture(e.pointerId);
        dragState = {
          dragging: true,
          path: [{ x: cell.x, y: cell.y }],
          visited: new Set([cell.x + ',' + cell.y]),
          current: cell
        };
        rawEvents = [{ x: coords.px / logW, y: coords.py / logH, t: performance.now(), type: 'down', pointer_type: ptrType(e) }];
        setHint('Tracing...');
        drawMaze();
      });

      canvas.addEventListener('pointermove', function(e) {
        if (!dragState || !dragState.dragging || completed) return;
        var coords = canvasCoords(e);
        var now = performance.now();
        rawEvents.push({ x: coords.px / logW, y: coords.py / logH, t: now, type: 'move', pointer_type: ptrType(e) });

        var cell = pxToCell(coords.px, coords.py);
        if (!cell || !dragState.current) return;
        if (cell.x === dragState.current.x && cell.y === dragState.current.y) {
          if (rawEvents.length > 10) updateFeatureDisplay();
          return;
        }
        if (!canPass(dragState.current.x, dragState.current.y, cell.x, cell.y)) return;

        var key = cell.x + ',' + cell.y;

        // Backtrack
        if (dragState.path.length >= 2) {
          var prev = dragState.path[dragState.path.length - 2];
          if (prev.x === cell.x && prev.y === cell.y) {
            var removed = dragState.path.pop();
            dragState.visited.delete(removed.x + ',' + removed.y);
            dragState.current = cell;
            drawMaze();
            return;
          }
        }

        if (dragState.visited.has(key)) return;

        dragState.path.push({ x: cell.x, y: cell.y });
        dragState.visited.add(key);
        dragState.current = cell;
        drawMaze();

        if (cell.x === maze.exit.x && cell.y === maze.exit.y) {
          completed = true;
          dragState.dragging = false;
          rawEvents.push({ x: coords.px / logW, y: coords.py / logH, t: performance.now(), type: 'up', pointer_type: ptrType(e) });
          updateFeatureDisplay();
          submitToServer();
        }
      });

      canvas.addEventListener('pointerup', function(e) {
        if (!dragState || !dragState.dragging) return;
        dragState.dragging = false;
        dragState.path = [];
        dragState.visited = new Set();
        dragState.current = null;
        rawEvents = [];
        drawMaze();
      });

      // ── Display helpers ──
      function setHint(text, color) {
        var el = document.getElementById('score-hint');
        el.textContent = text;
        el.style.color = color || '';
      }

      function updateFeatureDisplay() {
        var feat = extractFeatures(rawEvents);
        if (!feat) return;

        var feats = ['velocity_std', 'path_efficiency', 'pause_count', 'movement_onset_ms', 'jerk_std', 'angular_velocity_entropy', 'timing_cv'];
        var maxVals = {
          velocity_std: 0.001, path_efficiency: 1, pause_count: 6,
          movement_onset_ms: 2000, jerk_std: 2e-6, angular_velocity_entropy: 4, timing_cv: 1.5
        };

        feats.forEach(function(f) {
          var bar = document.querySelector('[data-feat="' + f + '"]');
          var val = document.querySelector('[data-val="' + f + '"]');
          if (bar) bar.style.width = Math.min(100, (feat[f] / maxVals[f]) * 100) + '%';
          if (val) {
            if (f === 'pause_count') val.textContent = Math.round(feat[f]);
            else if (f === 'movement_onset_ms') val.textContent = Math.round(feat[f]) + 'ms';
            else val.textContent = feat[f].toFixed(4);
          }
        });

        var score = scoreFeatures(feat);
        var sv = document.getElementById('score-value');
        sv.textContent = score.toFixed(2);
        sv.style.color = score > 0.6 ? '#16a34a' : '#dc2626';
      }

      function resetDisplay() {
        document.querySelectorAll('.bar-fill').forEach(function(b) { b.style.width = '0%'; });
        document.querySelectorAll('.val').forEach(function(v) { v.textContent = '\u2014'; });
        document.getElementById('score-value').textContent = '\u2014';
        document.getElementById('score-value').style.color = '';
      }

      // ── Server: submit verification ──
      async function submitToServer() {
        if (!challengeData) {
          // Local-only fallback — show local score
          var feat = extractFeatures(rawEvents);
          var score = feat ? scoreFeatures(feat) : 0;
          setHint(score > 0.6 ? 'Proof of human' : 'Non-human pattern', score > 0.6 ? '#16a34a' : '#dc2626');
          return;
        }
        setHint('Verifying...');
        try {
          var pow = await powPromise;
          var canonical = JSON.stringify(rawEvents.map(function(e) { return [e.t, e.x, e.y, e.type]; }));
          var digestBuf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(canonical));
          var digestArr = new Uint8Array(digestBuf);
          var eventsDigest = '';
          for (var di = 0; di < digestArr.length; di++) eventsDigest += digestArr[di].toString(16).padStart(2, '0');
          var binding = challengeData.id + ':' + challengeData.site_key + ':' + challengeData.expires_at + ':' + eventsDigest;
          var signature = await signBinding(binding, ecKeyPair.privateKey);

          var res = await fetch(API_URL + '/verify', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              challenge_id: challengeData.id,
              site_key: SITE_KEY,
              session_id: SESSION_ID,
              events: rawEvents,
              pow_proof: pow,
              public_key: ecKeyPair.publicKeyBase64,
              signature: signature,
              timestamp: Date.now()
            })
          });

          var result = await res.json();
          if (result.success) {
            setHint('Proof of human', '#16a34a');
          } else {
            var reason = result.error_code || 'rejected';
            setHint(reason === 'behavioral_rejected' ? 'Non-human pattern' : reason.replace(/_/g, ' '), '#dc2626');
          }
        } catch (err) {
          setHint('Connection error', '#dc2626');
        }
      }

      // ── Server: fetch challenge and init maze ──
      async function fetchChallenge() {
        resetDisplay();
        setHint('Loading challenge...');
        dragState = null;
        completed = false;
        rawEvents = [];
        if (powPromise && powPromise.cancel) powPromise.cancel();

        try {
          if (!ecKeyPair) ecKeyPair = await genKeyPair();

          var res = await fetch(API_URL + '/challenge', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              site_key: SITE_KEY,
              public_key: ecKeyPair.publicKeyBase64
            })
          });

          if (!res.ok) throw new Error('HTTP ' + res.status);
          challengeData = await res.json();

          // Generate maze from server challenge (exact same algorithm)
          CELL = challengeData.cell_size || 40;
          maze = generateMaze(
            challengeData.maze_seed,
            challengeData.maze_width,
            challengeData.maze_height,
            challengeData.maze_difficulty
          );
          recalcDimensions();

          // Start PoW in background
          powPromise = startPow(challengeData.pow_challenge, challengeData.pow_difficulty);

          setHint('Trace from green to red');
          drawMaze();
        } catch (err) {
          // Fallback to local-only mode if API unreachable
          console.warn('Cerno API unavailable, local demo:', err.message);
          challengeData = null;
          CELL = 40;
          var seed = (Date.now() ^ (Math.random() * 0xFFFFFFFF)) >>> 0;
          maze = generateMaze(seed, 7, 7, 0.3);
          recalcDimensions();
          setHint('Trace from green to red');
          drawMaze();
        }
      }

      document.getElementById('new-maze').addEventListener('click', function(e) {
        e.preventDefault();
        SESSION_ID = 'demo-' + Math.random().toString(36).slice(2) + Date.now().toString(36);
        fetchChallenge();
      });

      window.addEventListener('resize', function() { drawMaze(); });
      fetchChallenge();

      // ── Theme toggle ──
      var modes = ['auto', 'light', 'dark'];
      var toggleBtn = document.getElementById('theme-toggle');
      var stored = localStorage.getItem('starlight-theme');
      var currentMode = (stored === 'light' || stored === 'dark') ? stored : 'auto';

      function applyTheme(mode) {
        currentMode = mode;
        toggleBtn.setAttribute('data-mode', mode);
        var dark;
        if (mode === 'auto') {
          dark = matchMedia('(prefers-color-scheme:dark)').matches;
          localStorage.removeItem('starlight-theme');
        } else {
          dark = mode === 'dark';
          localStorage.setItem('starlight-theme', mode);
        }
        document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light');
        if (maze) drawMaze();
      }

      toggleBtn.setAttribute('data-mode', currentMode);
      toggleBtn.addEventListener('click', function() {
        var next = modes[(modes.indexOf(currentMode) + 1) % modes.length];
        applyTheme(next);
      });

      matchMedia('(prefers-color-scheme:dark)').addEventListener('change', function() {
        if (currentMode === 'auto') applyTheme('auto');
      });
    });
    </script>
  </body>
</html>
