---
// Cerno — cerno.sh
// Zero JS. Pure Astro + scoped CSS.
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Cerno — The last line between AI agents and your users</title>
    <meta
      name="description"
      content="Maze-trace CAPTCHA with behavioral biometrics. Invisible to humans. Impenetrable to agents."
    />
    <meta property="og:title" content="Cerno — AI-agent-proof CAPTCHA" />
    <meta
      property="og:description"
      content="Maze-trace CAPTCHA with behavioral biometrics. Invisible to humans. Impenetrable to agents."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://cerno.sh" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- ═══════════════ NAV ═══════════════ -->
    <nav class="nav">
      <div class="nav-inner">
        <a href="/" class="nav-logo">cerno</a>
        <div class="nav-links">
          <a href="#how-it-works">How it works</a>
          <a href="#integration">Integrate</a>
          <a href="https://github.com/veto-party/cerno" class="nav-gh">GitHub</a>
        </div>
      </div>
    </nav>

    <!-- ═══════════════ HERO ═══════════════ -->
    <section class="hero">
      <div class="maze-bg" aria-hidden="true">
        <div class="maze-grid">
          {Array.from({ length: 180 }).map((_, i) => (
            <div class="maze-cell" style={`--d:${(i * 37) % 60}; --r:${i % 4}`} />
          ))}
        </div>
      </div>
      <div class="hero-content">
        <h1 class="wordmark">Cerno</h1>
        <p class="tagline">The last line between AI&nbsp;agents and your&nbsp;users.</p>
        <p class="sub-tagline">
          Maze-trace CAPTCHA with behavioral biometrics.<br />
          Invisible to humans. Impenetrable to agents.
        </p>
        <div class="cta-row">
          <a href="#integration" class="btn btn-primary">Get Started</a>
          <a
            href="https://github.com/veto-party/cerno"
            class="btn btn-secondary"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg
              class="gh-icon"
              viewBox="0 0 16 16"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z" />
            </svg>
            View on GitHub
          </a>
        </div>
      </div>
    </section>

    <!-- ═══════════════ PROBLEM ═══════════════ -->
    <section class="section problem">
      <div class="container">
        <h2 class="section-heading">
          AI agents are getting smarter.<br />
          <span class="text-muted">Your CAPTCHA isn't.</span>
        </h2>
        <div class="stats-grid">
          <div class="stat-card">
            <span class="stat-number">60%</span>
            <span class="stat-label">of reCAPTCHA v2 solved by Claude</span>
            <span class="stat-source">Roundtable benchmark, 2024</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">90%+</span>
            <span class="stat-label">solve rate from CAPTCHA bypass services</span>
            <span class="stat-source">Industry data</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">2025</span>
            <span class="stat-label">AI agents use browsers like humans</span>
            <span class="stat-source">browser-use, Playwright, Stagehand</span>
          </div>
        </div>
        <p class="problem-explanation">
          Traditional CAPTCHAs test what you <em>know</em>&thinsp;&mdash;&thinsp;identify a bus, read distorted text.
          AI can do that now. Cerno tests how you <em>move</em>.
        </p>
      </div>
    </section>

    <!-- ═══════════════ HOW IT WORKS ═══════════════ -->
    <section class="section how" id="how-it-works">
      <div class="container">
        <span class="section-label">How it works</span>
        <h2 class="section-heading">Three layers. Zero trust.</h2>
        <div class="layers-grid">
          <div class="layer-card">
            <div class="layer-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="7" width="20" height="14" rx="2" />
                <path d="M12 11v4M9 13h6" />
                <path d="M6 7V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2" />
              </svg>
            </div>
            <h3>Proof of Work</h3>
            <p class="layer-subtitle">Economics layer</p>
            <p>
              SHA-256 mining runs in the background. Imperceptible to a single user.
              Makes farm attacks economically infeasible at scale.
            </p>
          </div>
          <div class="layer-card">
            <div class="layer-icon accent-cyan">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2" />
                <path d="M3 9h18M9 3v18M15 9v6M9 15h6" />
              </svg>
            </div>
            <h3>Maze Challenge</h3>
            <p class="layer-subtitle">Spatial reasoning</p>
            <p>
              A unique procedural maze generated per session. AI agents struggle to
              navigate spatial layouts through vision alone. Humans trace the path
              intuitively.
            </p>
          </div>
          <div class="layer-card">
            <div class="layer-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 12c0 0 4-8 10-8s10 8 10 8-4 8-10 8S2 12 2 12z" />
                <circle cx="12" cy="12" r="3" />
              </svg>
            </div>
            <h3>Behavioral Biometrics</h3>
            <p class="layer-subtitle">The real test</p>
            <p>
              6 features extracted from your mouse movements. Velocity variance. Jerk
              dynamics. Angular entropy. Pause-move ratios. Things AI can't fake.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════ CODE / INTEGRATION ═══════════════ -->
    <section class="section code-section" id="integration">
      <div class="container">
        <span class="section-label">Integration</span>
        <h2 class="section-heading">Ship in minutes, not&nbsp;sprints.</h2>
        <div class="code-grid">
          <div class="code-block">
            <div class="code-header">
              <span class="code-dot red"></span>
              <span class="code-dot yellow"></span>
              <span class="code-dot green"></span>
              <span class="code-filename">ProtectedForm.tsx</span>
            </div>
            <pre><code><span class="kw">import</span> {"{"} <span class="fn">Cerno</span> {"}"} <span class="kw">from</span> <span class="str">'@cernosh/react'</span>

<span class="kw">function</span> <span class="fn">ProtectedForm</span>() {"{"}
  <span class="kw">return</span> (
    &lt;<span class="fn">Cerno</span>
      <span class="attr">siteKey</span>=<span class="str">"your-site-key"</span>
      <span class="attr">sessionId</span>={"{"}session.id{"}"}
      <span class="attr">onVerify</span>={"{"}(<span class="param">token</span>) =&gt; <span class="fn">submitForm</span>(token){"}"}
    /&gt;
  )
{"}"}</code></pre>
          </div>
          <div class="code-block">
            <div class="code-header">
              <span class="code-dot red"></span>
              <span class="code-dot yellow"></span>
              <span class="code-dot green"></span>
              <span class="code-filename">verify.ts</span>
            </div>
            <pre><code><span class="kw">import</span> {"{"} <span class="fn">verifyToken</span> {"}"} <span class="kw">from</span> <span class="str">'@cernosh/server'</span>

<span class="kw">const</span> result = <span class="kw">await</span> <span class="fn">verifyToken</span>(token, {"{"}
  <span class="attr">secret</span>: process.env.<span class="const">CERNO_SECRET</span>,
  <span class="attr">sessionId</span>: req.session.id,
{"}"})

<span class="cmt">// result: {"{"} valid: boolean, score: number {"}"}</span></code></pre>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════ ARCHITECTURE ═══════════════ -->
    <section class="section architecture">
      <div class="container">
        <span class="section-label">Architecture</span>
        <h2 class="section-heading">Three gates. One verdict.</h2>
        <div class="pipeline">
          <div class="pipeline-step">
            <div class="pipeline-node">
              <span class="pipeline-num">1</span>
            </div>
            <div class="pipeline-info">
              <h3>PoW Mining</h3>
              <p>Client computes SHA-256 nonce. Difficulty scales with risk score. 200ms for humans, costly for farms.</p>
            </div>
          </div>
          <div class="pipeline-connector" aria-hidden="true"></div>
          <div class="pipeline-step">
            <div class="pipeline-node cyan">
              <span class="pipeline-num">2</span>
            </div>
            <div class="pipeline-info">
              <h3>Maze Solve</h3>
              <p>User traces a procedurally generated maze. Path is recorded as coordinate stream. Validates spatial reasoning.</p>
            </div>
          </div>
          <div class="pipeline-connector" aria-hidden="true"></div>
          <div class="pipeline-step">
            <div class="pipeline-node">
              <span class="pipeline-num">3</span>
            </div>
            <div class="pipeline-info">
              <h3>Behavioral Analysis</h3>
              <p>6 biometric features scored against known human distributions. Deterministic threshold. No ML on the hot path.</p>
            </div>
          </div>
          <div class="pipeline-connector" aria-hidden="true"></div>
          <div class="pipeline-result">
            <div class="result-human">&#10003; Human</div>
            <div class="result-divider">/</div>
            <div class="result-agent">&#10007; Agent</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════ WHY CERNO ═══════════════ -->
    <section class="section why">
      <div class="container">
        <span class="section-label">Why Cerno</span>
        <h2 class="section-heading">Built for a post-agent world.</h2>
        <div class="why-grid">
          <div class="why-card">
            <h3>Not bot detection.<br /><span class="accent">AI safety policy enforcement.</span></h3>
            <p>
              Bots are scripts. Agents are intelligent. Cerno is designed for the latter&thinsp;&mdash;&thinsp;systems
              that reason, adapt, and use real browsers.
            </p>
          </div>
          <div class="why-card">
            <h3>The maze is a Trojan horse.<br /><span class="accent-cyan">The real test is invisible.</span></h3>
            <p>
              Users see a maze. The system sees velocity curves, angular distributions, pause-move ratios.
              The challenge is cover. The biometrics are the verdict.
            </p>
          </div>
          <div class="why-card">
            <h3>Deterministic scoring.<br /><span class="accent">Sub-50ms server validation.</span></h3>
            <p>
              No ML inference on the hot path. Statistical thresholds against known human distributions.
              Fast, predictable, auditable.
            </p>
          </div>
          <div class="why-card">
            <h3>Open source. Self-host.<br /><span class="accent-cyan">Own your verification.</span></h3>
            <p>
              Deploy on Cloudflare Workers. No third-party dependencies. No data leaves your infrastructure.
              MIT licensed.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════ FOOTER ═══════════════ -->
    <footer class="footer">
      <div class="container footer-inner">
        <div class="footer-left">
          <span class="footer-logo">cerno</span>
          <span class="footer-dot">&middot;</span>
          <span class="footer-domain">cerno.sh</span>
        </div>
        <div class="footer-center">
          Built by <a href="https://veto.so" target="_blank" rel="noopener noreferrer">veto.so</a>
        </div>
        <div class="footer-right">
          <a href="https://github.com/veto-party/cerno" target="_blank" rel="noopener noreferrer">GitHub</a>
          <span class="footer-dot">&middot;</span>
          <span>MIT License</span>
        </div>
      </div>
    </footer>

    <style>
      /* ═══════════════ RESET & BASE ═══════════════ */
      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
          sans-serif;
        background: #0a0a0a;
        color: #fafafa;
        line-height: 1.6;
        overflow-x: hidden;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .container {
        max-width: 1120px;
        margin: 0 auto;
        padding: 0 24px;
      }

      /* ═══════════════ NAV ═══════════════ */
      .nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        background: rgba(10, 10, 10, 0.8);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      }

      .nav-inner {
        max-width: 1120px;
        margin: 0 auto;
        padding: 0 24px;
        height: 56px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .nav-logo {
        font-weight: 700;
        font-size: 1.125rem;
        letter-spacing: -0.02em;
        color: #fafafa;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 28px;
        font-size: 0.875rem;
        color: #a1a1aa;
      }

      .nav-links a:hover {
        color: #fafafa;
        transition: color 0.15s;
      }

      .nav-gh {
        color: #fafafa !important;
        font-weight: 500;
      }

      /* ═══════════════ HERO ═══════════════ */
      .hero {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 120px 24px 80px;
        overflow: hidden;
      }

      /* Animated maze background */
      .maze-bg {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0.06;
        pointer-events: none;
      }

      .maze-grid {
        display: grid;
        grid-template-columns: repeat(18, 1fr);
        grid-template-rows: repeat(10, 1fr);
        width: 100%;
        max-width: 1400px;
        aspect-ratio: 18 / 10;
        gap: 0;
      }

      .maze-cell {
        border: 1px solid transparent;
        animation: maze-shift 8s ease-in-out infinite;
        animation-delay: calc(var(--d) * -0.12s);
      }

      @keyframes maze-shift {
        0%,
        100% {
          border-color: transparent;
        }
        20% {
          border-top-color: #6366f1;
          border-right-color: transparent;
          border-bottom-color: transparent;
          border-left-color: #6366f1;
        }
        40% {
          border-top-color: transparent;
          border-right-color: #22d3ee;
          border-bottom-color: #6366f1;
          border-left-color: transparent;
        }
        60% {
          border-top-color: #22d3ee;
          border-right-color: transparent;
          border-bottom-color: transparent;
          border-left-color: #22d3ee;
        }
        80% {
          border-top-color: transparent;
          border-right-color: #6366f1;
          border-bottom-color: #22d3ee;
          border-left-color: transparent;
        }
      }

      .hero-content {
        position: relative;
        z-index: 1;
        text-align: center;
        max-width: 720px;
      }

      .wordmark {
        font-size: clamp(4rem, 12vw, 8rem);
        font-weight: 800;
        letter-spacing: -0.04em;
        line-height: 1;
        background: linear-gradient(135deg, #fafafa 0%, #a1a1aa 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 24px;
      }

      .tagline {
        font-size: clamp(1.25rem, 3vw, 1.75rem);
        font-weight: 600;
        letter-spacing: -0.01em;
        color: #fafafa;
        margin-bottom: 16px;
      }

      .sub-tagline {
        font-size: clamp(0.95rem, 2vw, 1.125rem);
        color: #a1a1aa;
        line-height: 1.7;
        margin-bottom: 40px;
      }

      .cta-row {
        display: flex;
        gap: 16px;
        justify-content: center;
        flex-wrap: wrap;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 28px;
        border-radius: 8px;
        font-size: 0.9375rem;
        font-weight: 600;
        transition: all 0.2s;
        cursor: pointer;
      }

      .btn-primary {
        background: #6366f1;
        color: #fff;
      }

      .btn-primary:hover {
        background: #818cf8;
        box-shadow: 0 0 32px rgba(99, 102, 241, 0.3);
      }

      .btn-secondary {
        background: rgba(255, 255, 255, 0.06);
        color: #fafafa;
        border: 1px solid rgba(255, 255, 255, 0.1);
      }

      .btn-secondary:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.2);
      }

      .gh-icon {
        width: 16px;
        height: 16px;
      }

      /* ═══════════════ SECTIONS (shared) ═══════════════ */
      .section {
        padding: 120px 0;
        position: relative;
      }

      .section-label {
        display: inline-block;
        font-size: 0.8125rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #6366f1;
        margin-bottom: 16px;
      }

      .section-heading {
        font-size: clamp(1.75rem, 4vw, 2.75rem);
        font-weight: 700;
        letter-spacing: -0.025em;
        line-height: 1.2;
        margin-bottom: 56px;
      }

      .text-muted {
        color: #71717a;
      }

      .accent {
        color: #6366f1;
      }

      .accent-cyan {
        color: #22d3ee;
      }

      /* ═══════════════ PROBLEM ═══════════════ */
      .problem {
        border-top: 1px solid rgba(255, 255, 255, 0.06);
      }

      .problem .section-heading {
        text-align: center;
      }

      .stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
        margin-bottom: 48px;
      }

      .stat-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 12px;
        padding: 32px 24px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        transition: border-color 0.3s;
      }

      .stat-card:hover {
        border-color: rgba(99, 102, 241, 0.3);
      }

      .stat-number {
        font-size: 2.5rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        background: linear-gradient(135deg, #6366f1, #22d3ee);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        line-height: 1.1;
      }

      .stat-label {
        font-size: 0.9375rem;
        color: #d4d4d8;
        line-height: 1.5;
      }

      .stat-source {
        font-size: 0.75rem;
        color: #52525b;
        font-style: italic;
      }

      .problem-explanation {
        text-align: center;
        max-width: 600px;
        margin: 0 auto;
        font-size: 1.0625rem;
        color: #a1a1aa;
        line-height: 1.7;
      }

      .problem-explanation em {
        color: #fafafa;
        font-style: normal;
        font-weight: 600;
      }

      /* ═══════════════ HOW IT WORKS ═══════════════ */
      .how {
        border-top: 1px solid rgba(255, 255, 255, 0.06);
      }

      .layers-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
      }

      .layer-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 12px;
        padding: 32px 28px;
        transition: border-color 0.3s, transform 0.3s;
      }

      .layer-card:hover {
        border-color: rgba(99, 102, 241, 0.3);
        transform: translateY(-2px);
      }

      .layer-icon {
        width: 40px;
        height: 40px;
        color: #6366f1;
        margin-bottom: 20px;
      }

      .layer-icon.accent-cyan {
        color: #22d3ee;
      }

      .layer-card h3 {
        font-size: 1.125rem;
        font-weight: 700;
        margin-bottom: 4px;
      }

      .layer-subtitle {
        font-size: 0.8125rem;
        color: #6366f1;
        font-weight: 500;
        margin-bottom: 12px;
        display: block;
      }

      .layer-card:nth-child(2) .layer-subtitle {
        color: #22d3ee;
      }

      .layer-card p:last-child {
        font-size: 0.9375rem;
        color: #a1a1aa;
        line-height: 1.6;
      }

      /* ═══════════════ CODE ═══════════════ */
      .code-section {
        border-top: 1px solid rgba(255, 255, 255, 0.06);
      }

      .code-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 24px;
      }

      .code-block {
        background: #111113;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 12px;
        overflow: hidden;
      }

      .code-header {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px 16px;
        background: rgba(255, 255, 255, 0.03);
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      }

      .code-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
      }

      .code-dot.red {
        background: #ef4444;
        opacity: 0.7;
      }

      .code-dot.yellow {
        background: #eab308;
        opacity: 0.7;
      }

      .code-dot.green {
        background: #22c55e;
        opacity: 0.7;
      }

      .code-filename {
        margin-left: 8px;
        font-size: 0.8125rem;
        color: #71717a;
        font-family: 'JetBrains Mono', ui-monospace, 'SFMono-Regular', Menlo, monospace;
      }

      .code-block pre {
        padding: 20px;
        overflow-x: auto;
        scrollbar-width: thin;
        scrollbar-color: #27272a transparent;
      }

      .code-block code {
        font-family: 'JetBrains Mono', ui-monospace, 'SFMono-Regular', Menlo, monospace;
        font-size: 0.8125rem;
        line-height: 1.7;
        color: #d4d4d8;
      }

      .kw {
        color: #c084fc;
      }

      .fn {
        color: #67e8f9;
      }

      .str {
        color: #86efac;
      }

      .attr {
        color: #fbbf24;
      }

      .param {
        color: #fb923c;
      }

      .const {
        color: #f472b6;
      }

      .cmt {
        color: #52525b;
        font-style: italic;
      }

      /* ═══════════════ ARCHITECTURE ═══════════════ */
      .architecture {
        border-top: 1px solid rgba(255, 255, 255, 0.06);
      }

      .pipeline {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0;
        max-width: 560px;
        margin: 0 auto;
      }

      .pipeline-step {
        display: flex;
        align-items: flex-start;
        gap: 24px;
        width: 100%;
        padding: 24px;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 12px;
        transition: border-color 0.3s;
      }

      .pipeline-step:hover {
        border-color: rgba(99, 102, 241, 0.3);
      }

      .pipeline-node {
        flex-shrink: 0;
        width: 44px;
        height: 44px;
        border-radius: 10px;
        background: rgba(99, 102, 241, 0.15);
        border: 1px solid rgba(99, 102, 241, 0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #6366f1;
        font-weight: 700;
        font-size: 1rem;
      }

      .pipeline-node.cyan {
        background: rgba(34, 211, 238, 0.1);
        border-color: rgba(34, 211, 238, 0.3);
        color: #22d3ee;
      }

      .pipeline-num {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
      }

      .pipeline-info h3 {
        font-size: 1rem;
        font-weight: 700;
        margin-bottom: 4px;
      }

      .pipeline-info p {
        font-size: 0.875rem;
        color: #a1a1aa;
        line-height: 1.6;
      }

      .pipeline-connector {
        width: 2px;
        height: 24px;
        background: linear-gradient(to bottom, rgba(99, 102, 241, 0.3), rgba(34, 211, 238, 0.3));
      }

      .pipeline-result {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 20px 32px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 12px;
        font-weight: 700;
        font-size: 1.0625rem;
      }

      .result-human {
        color: #22c55e;
      }

      .result-divider {
        color: #3f3f46;
      }

      .result-agent {
        color: #ef4444;
      }

      /* ═══════════════ WHY CERNO ═══════════════ */
      .why {
        border-top: 1px solid rgba(255, 255, 255, 0.06);
      }

      .why-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 24px;
      }

      .why-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 12px;
        padding: 32px 28px;
        transition: border-color 0.3s;
      }

      .why-card:hover {
        border-color: rgba(99, 102, 241, 0.2);
      }

      .why-card h3 {
        font-size: 1.0625rem;
        font-weight: 700;
        line-height: 1.4;
        margin-bottom: 12px;
      }

      .why-card h3 .accent {
        color: #6366f1;
      }

      .why-card h3 .accent-cyan {
        color: #22d3ee;
      }

      .why-card p {
        font-size: 0.9375rem;
        color: #a1a1aa;
        line-height: 1.6;
      }

      /* ═══════════════ FOOTER ═══════════════ */
      .footer {
        border-top: 1px solid rgba(255, 255, 255, 0.06);
        padding: 24px 0;
      }

      .footer-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 0.8125rem;
        color: #71717a;
      }

      .footer-logo {
        font-weight: 700;
        color: #a1a1aa;
        font-size: 0.875rem;
      }

      .footer-domain {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 0.75rem;
      }

      .footer-dot {
        color: #3f3f46;
        margin: 0 4px;
      }

      .footer-center a {
        color: #6366f1;
        font-weight: 500;
        transition: color 0.15s;
      }

      .footer-center a:hover {
        color: #818cf8;
      }

      .footer-right {
        display: flex;
        align-items: center;
      }

      .footer-right a {
        color: #71717a;
        transition: color 0.15s;
      }

      .footer-right a:hover {
        color: #fafafa;
      }

      .footer-left {
        display: flex;
        align-items: center;
      }

      /* ═══════════════ RESPONSIVE ═══════════════ */
      @media (max-width: 768px) {
        .section {
          padding: 80px 0;
        }

        .section-heading {
          margin-bottom: 40px;
        }

        .stats-grid,
        .layers-grid {
          grid-template-columns: 1fr;
        }

        .code-grid {
          grid-template-columns: 1fr;
        }

        .why-grid {
          grid-template-columns: 1fr;
        }

        .nav-links a:not(.nav-gh) {
          display: none;
        }

        .footer-inner {
          flex-direction: column;
          gap: 12px;
          text-align: center;
        }

        .hero {
          padding: 100px 24px 60px;
          min-height: auto;
        }

        .wordmark {
          margin-bottom: 16px;
        }

        .cta-row {
          flex-direction: column;
          align-items: center;
        }

        .btn {
          width: 100%;
          max-width: 280px;
          justify-content: center;
        }

        .pipeline-step {
          gap: 16px;
          padding: 20px 16px;
        }
      }

      @media (max-width: 480px) {
        .section {
          padding: 64px 0;
        }

        .stat-number {
          font-size: 2rem;
        }

        .pipeline-info h3 {
          font-size: 0.9375rem;
        }

        .pipeline-info p {
          font-size: 0.8125rem;
        }
      }

      /* ═══════════════ SUBTLE GLOW EFFECTS ═══════════════ */
      .hero::after {
        content: '';
        position: absolute;
        top: 20%;
        left: 50%;
        transform: translateX(-50%);
        width: 600px;
        height: 400px;
        background: radial-gradient(
          ellipse at center,
          rgba(99, 102, 241, 0.08) 0%,
          rgba(34, 211, 238, 0.03) 40%,
          transparent 70%
        );
        pointer-events: none;
        z-index: 0;
      }

      .problem::before {
        content: '';
        position: absolute;
        top: 0;
        right: 0;
        width: 400px;
        height: 400px;
        background: radial-gradient(
          circle at top right,
          rgba(99, 102, 241, 0.04) 0%,
          transparent 60%
        );
        pointer-events: none;
      }

      .architecture::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 0;
        transform: translateY(-50%);
        width: 300px;
        height: 500px;
        background: radial-gradient(
          circle at left,
          rgba(34, 211, 238, 0.03) 0%,
          transparent 60%
        );
        pointer-events: none;
      }

      /* ═══════════════ SELECTION ═══════════════ */
      ::selection {
        background: rgba(99, 102, 241, 0.3);
        color: #fafafa;
      }

      /* ═══════════════ SCROLLBAR ═══════════════ */
      ::-webkit-scrollbar {
        width: 8px;
      }

      ::-webkit-scrollbar-track {
        background: #0a0a0a;
      }

      ::-webkit-scrollbar-thumb {
        background: #27272a;
        border-radius: 4px;
      }

      ::-webkit-scrollbar-thumb:hover {
        background: #3f3f46;
      }
    </style>
  </body>
</html>
