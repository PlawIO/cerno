---
// cerno.sh
const enableReactGrab = import.meta.env.DEV
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Cerno — Human verification without hardware</title>
    <meta name="description" content="Open-source TypeScript SDK for human verification. Maze interaction with motor-control analysis, 12 behavioral features scored server-side against per-maze baselines. No ML inference, no third-party calls." />
    <link rel="canonical" href="https://cerno.sh" />
    <meta property="og:title" content="Cerno — Human verification without hardware" />
    <meta property="og:description" content="Open-source verification SDK. Maze interaction, motor-control analysis, server-side behavioral scoring. No ML inference." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://cerno.sh" />
    <meta property="og:image" content="https://cerno.sh/og.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Cerno — Human verification without hardware" />
    <meta name="twitter:description" content="Open-source verification SDK. Maze interaction, motor-control analysis, server-side behavioral scoring." />
    <meta name="twitter:image" content="https://cerno.sh/og.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="color-scheme" content="light dark" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <script is:inline>
      // Anti-FOUC: resolve theme before paint. Syncs with Starlight's localStorage key.
      (function(){
        var s = localStorage.getItem('starlight-theme');
        var dark = s === 'dark' || (!s && matchMedia('(prefers-color-scheme:dark)').matches);
        document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light');
      })();
    </script>
    {enableReactGrab && (
      <>
        <script src="//unpkg.com/react-grab/dist/index.global.js" crossorigin="anonymous"></script>
        <script src="//unpkg.com/@react-grab/claude-code/dist/client.global.js" crossorigin="anonymous"></script>
      </>
    )}
    <style>
      @font-face {
        font-family: 'Geist';
        src: url('https://cdn.jsdelivr.net/npm/geist@1.7.0/dist/fonts/geist-sans/Geist-Variable.woff2') format('woff2');
        font-weight: 100 900;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'Geist Mono';
        src: url('https://cdn.jsdelivr.net/npm/geist@1.7.0/dist/fonts/geist-mono/GeistMono-Variable.woff2') format('woff2');
        font-weight: 100 900;
        font-style: normal;
        font-display: swap;
      }
    </style>
  </head>
  <body>
    <nav>
      <div class="nav-inner">
        <a href="/" class="logo">
          <svg class="logo-mark" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <g stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <line x1="13" y1="3" x2="33" y2="3"/>
              <line x1="33" y1="3" x2="33" y2="33"/>
              <line x1="3" y1="33" x2="23" y2="33"/>
              <line x1="3" y1="3" x2="3" y2="33"/>
              <line x1="13" y1="13" x2="13" y2="23"/>
              <line x1="23" y1="3" x2="23" y2="13"/>
              <line x1="23" y1="23" x2="23" y2="33"/>
              <line x1="13" y1="23" x2="23" y2="23"/>
            </g>
            <path d="M8 3 L8 8 L18 8 L18 18 L28 18 L28 28 L28 33" stroke="#2596be" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Cerno
        </a>
        <div class="nav-r">
          <a href="/docs/">Docs</a>
          <a href="/dashboard">Dashboard</a>
          <a href="https://github.com/PlawIO/cerno" target="_blank" rel="noopener">GitHub</a>
          <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
            <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            <svg class="icon-auto" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </button>
        </div>
      </div>
    </nav>

    <main>
      <section class="hero">
        <div class="hero-center">
          <h1>Human verification<br/>without hardware</h1>
          <p class="sub">
            Motor-control analysis of maze interaction.<span class="hide-mobile"> Open-source TypeScript SDK.</span><span class="show-mobile"> Open source.</span>
          </p>
          <div class="hero-actions">
            <div class="install-line">
              <code><button class="pm-switch" id="pm-switch" aria-label="Switch package manager">npm i</button> @cernosh/react @cernosh/server</code>
              <button class="copy-btn" id="pkg-copy" aria-label="Copy">
                <svg class="copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                <svg class="check-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </button>
            </div>
            <div class="ctas">
              <a href="/docs/getting-started/" class="btn-accent">Read Docs</a>
              <a href="https://github.com/PlawIO/cerno" class="btn-outline" target="_blank" rel="noopener">GitHub &rarr;</a>
            </div>
          </div>
        </div>
      </section>

      <section class="demo">
        <p class="section-label">DEMO</p>
        <div class="demo-grid">
          <div class="maze-wrap">
            <canvas id="maze-canvas"></canvas>
            <button id="new-maze" class="new-maze">New maze</button>
          </div>
          <div class="score-panel" id="score-panel">
            <div class="score-features">
              <div class="score-row"><code>velocity_std</code><div class="bar"><div class="bar-fill" data-feat="velocity_std"></div></div><span class="val" data-val="velocity_std">&mdash;</span></div>
              <div class="score-row"><code>path_efficiency</code><div class="bar"><div class="bar-fill" data-feat="path_efficiency"></div></div><span class="val" data-val="path_efficiency">&mdash;</span></div>
              <div class="score-row"><code>pause_count</code><div class="bar"><div class="bar-fill" data-feat="pause_count"></div></div><span class="val" data-val="pause_count">&mdash;</span></div>
              <div class="score-row"><code>movement_onset_ms</code><div class="bar"><div class="bar-fill" data-feat="movement_onset_ms"></div></div><span class="val" data-val="movement_onset_ms">&mdash;</span></div>
              <div class="score-row"><code>jerk_std</code><div class="bar"><div class="bar-fill" data-feat="jerk_std"></div></div><span class="val" data-val="jerk_std">&mdash;</span></div>
              <div class="score-row"><code>angular_velocity_entropy</code><div class="bar"><div class="bar-fill" data-feat="angular_velocity_entropy"></div></div><span class="val" data-val="angular_velocity_entropy">&mdash;</span></div>
              <div class="score-row"><code>timing_cv</code><div class="bar"><div class="bar-fill" data-feat="timing_cv"></div></div><span class="val" data-val="timing_cv">&mdash;</span></div>
            </div>
            <div class="score-total">
              <span class="score-label">Score</span>
              <span class="score-value" id="score-value">&mdash;</span>
            </div>
            <p class="score-hint" id="score-hint">Trace from green to red</p>
          </div>
        </div>
      </section>

      <section class="layers">
        <p class="section-label">PIPELINE</p>

        <div class="layer">
          <span class="num">01</span>
          <div>
            <strong>Proof of work</strong>
            <span class="desc">SHA-256 hash prefix, 14&ndash;24 bits. Adaptive difficulty based on client signals.</span>
          </div>
        </div>

        <div class="layer">
          <span class="num">02</span>
          <div>
            <strong>Maze generation</strong>
            <span class="desc">Growing Tree algorithm, seeded PRNG. Server regenerates from seed for trustless validation.</span>
          </div>
        </div>

        <div class="layer">
          <span class="num">03</span>
          <div>
            <strong>Motor-control analysis</strong>
            <span class="desc">12 behavioral features (7 public + 5 secret, server-only) extracted from raw pointer events. Scored against per-maze baselines.</span>
          </div>
        </div>

        <div class="layer">
          <span class="num">04</span>
          <div>
            <strong>Stroop probes</strong>
            <span class="desc">Color-word interference at maze decision points. Server derives timing from event stream.</span>
          </div>
        </div>

        <div class="layer">
          <span class="num">05</span>
          <div>
            <strong>Signature binding</strong>
            <span class="desc">ECDSA P-256 ephemeral keypair. Public key bound at challenge issuance, verified on submission.</span>
          </div>
        </div>

        <div class="layer">
          <span class="num">06</span>
          <div>
            <strong>Reputation</strong>
            <span class="desc">Behavioral consistency across sessions. EMA trust scores keyed by stable device identifier.</span>
          </div>
        </div>
      </section>

      <section class="features">
        <p class="section-label">FEATURES EXTRACTED</p>
        <div class="feat-grid">
          <div class="feat"><code>velocity_std</code><span>Standard deviation of tangential velocity across 60Hz resampled trajectory.</span></div>
          <div class="feat"><code>path_efficiency</code><span>Euclidean start-to-exit distance divided by actual path length.</span></div>
          <div class="feat"><code>pause_count</code><span>Intervals where velocity &lt; 0.0005 for &ge; 100ms. Correlated with maze decision points.</span></div>
          <div class="feat"><code>movement_onset_ms</code><span>Time from first event to first significant movement above threshold.</span></div>
          <div class="feat"><code>jerk_std</code><span>Standard deviation of the third derivative of position.</span></div>
          <div class="feat"><code>angular_velocity_entropy</code><span>Shannon entropy of direction changes across 16 angular bins.</span></div>
          <div class="feat"><code>timing_cv</code><span>Coefficient of variation of raw inter-event intervals. Computed pre-resampling.</span></div>
        </div>
      </section>

      <section class="code-section">
        <p class="section-label">INTEGRATION</p>
        <div class="code-grid">
          <div class="block">
            <div class="block-h"><span>ProtectedForm.tsx</span><button class="copy-btn" data-copy-from="code-client" aria-label="Copy"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg></button></div>
            <pre><code id="code-client"><span class="kw">import</span> {"{"} <span class="lit">Cerno</span> {"}"} <span class="kw">from</span> <span class="str">'@cernosh/react'</span>

<span class="kw">function</span> <span class="fn">ProtectedForm</span>() {"{"}
  <span class="kw">return</span> (
    &lt;<span class="lit">Cerno</span>
      <span class="prop">siteKey</span>=<span class="str">"ck_05a716da..."</span>
      <span class="prop">sessionId</span>={"{"}session.id{"}"}
      <span class="prop">onVerify</span>={"{"}(token) =&gt; <span class="fn">submit</span>(token){"}"}
    /&gt;
  )
{"}"}</code></pre>
          </div>
          <div class="block">
            <div class="block-h"><span>verify.ts</span><button class="copy-btn" data-copy-from="code-server" aria-label="Copy"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg></button></div>
            <pre><code id="code-server"><span class="kw">import</span> {"{"} <span class="lit">verifyToken</span> {"}"} <span class="kw">from</span> <span class="str">'@cernosh/server'</span>

<span class="kw">const</span> result = <span class="kw">await</span> <span class="fn">verifyToken</span>(token, {"{"}
  <span class="prop">secret</span>: process.env.<span class="lit">CERNO_SECRET</span>,
  <span class="prop">sessionId</span>: req.session.id,
{"}"})

<span class="cm">// {"{"} valid: boolean {"}"}</span></code></pre>
          </div>
        </div>
      </section>
    </main>

    <footer>
      <div class="footer-inner">
        <div class="footer-left">
          <svg class="footer-mark" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <g stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <line x1="13" y1="3" x2="33" y2="3"/>
              <line x1="33" y1="3" x2="33" y2="33"/>
              <line x1="3" y1="33" x2="23" y2="33"/>
              <line x1="3" y1="3" x2="3" y2="33"/>
              <line x1="13" y1="13" x2="13" y2="23"/>
              <line x1="23" y1="3" x2="23" y2="13"/>
              <line x1="23" y1="23" x2="23" y2="33"/>
              <line x1="13" y1="23" x2="23" y2="23"/>
            </g>
            <path d="M8 3 L8 8 L18 8 L18 18 L28 18 L28 28 L28 33" stroke="#2596be" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="footer-name">Cerno</span>
        </div>
        <div class="footer-links">
          <a href="/docs/">Docs</a>
          <a href="/dashboard">Dashboard</a>
          <a href="https://github.com/PlawIO/cerno" target="_blank" rel="noopener">GitHub</a>
          <a href="https://veto.so" target="_blank" rel="noopener">veto.so</a>
        </div>
        <div class="footer-right">
          <span>Apache 2.0</span>
        </div>
      </div>
    </footer>

    <style>
      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

      :root, [data-theme='light'] {
        --bg: #ffffff;
        --fg: #282828;
        --secondary: #504944;
        --muted: #6b6866;
        --border: rgba(0,0,0,0.06);
        --border-strong: rgba(0,0,0,0.12);
        --surface: #f3f3f2;
        --accent: #2596be;
        --accent-deep: #1d7898;
        --accent-text: #042f2e;
        --nav-bg: rgba(255, 255, 255, 0.9);
        --canvas-bg: #f8fafc;
        --canvas-wall: #1e293b;
        --scrollbar: rgba(0,0,0,0.1);
        --mono: 'Geist Mono', ui-monospace, monospace;
        --sans: 'Geist', ui-sans-serif, system-ui, sans-serif;
        --serif: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, serif;
        color-scheme: light;
      }

      [data-theme='dark'] {
        --bg: #0d0a09;
        --fg: #f3ece4;
        --secondary: #c5beb5;
        --muted: #978f87;
        --border: rgba(255, 245, 230, 0.08);
        --border-strong: rgba(255, 245, 230, 0.14);
        --surface: #1a1614;
        --accent: #38a9d2;
        --accent-deep: #5bbde0;
        --accent-text: #b2e7fb;
        --nav-bg: rgba(13, 10, 9, 0.9);
        --canvas-bg: #0f172a;
        --canvas-wall: #cbd5e1;
        --scrollbar: rgba(255,245,230,0.1);
        color-scheme: dark;
      }

      /* Dark mode syntax highlighting */
      [data-theme='dark'] .block .kw { color: #5bbde0; }
      [data-theme='dark'] .block .fn { color: #5bbde0; }
      [data-theme='dark'] .block .str { color: #a3d977; }
      [data-theme='dark'] .block .prop { color: #e87b85; }
      [data-theme='dark'] .block .cm { color: #978f87; }
      [data-theme='dark'] .block .lit { color: #f3ece4; }
      [data-theme='dark'] .block code { color: #c5beb5; }

      html { -webkit-font-smoothing: antialiased; }

      body {
        font-family: var(--sans);
        background: var(--bg);
        color: var(--fg);
        line-height: 1.5;
        font-size: 15px;
        letter-spacing: -0.011em;
      }

      a { color: inherit; text-decoration: none; }

      /* NAV */
      nav {
        position: sticky;
        top: 0;
        z-index: 100;
        background: var(--nav-bg);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
      }

      .nav-inner {
        max-width: 720px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 32px;
        height: 56px;
      }

      .logo {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: var(--mono);
        font-weight: 500;
        font-size: 15px;
        letter-spacing: -0.02em;
      }

      .logo-mark { width: 20px; height: 20px; flex-shrink: 0; }

      .nav-r {
        display: flex;
        gap: 24px;
        font-size: 14px;
        color: var(--muted);
      }

      .nav-r a {
        transition: color 0.15s;
        min-height: 44px;
        display: inline-flex;
        align-items: center;
      }
      .nav-r a:hover { color: var(--fg); }

      /* MAIN */
      main {
        max-width: 680px;
        margin: 0 auto;
        padding: 0 32px;
      }

      /* HERO — centered, breathing, PayKit-style */
      .hero {
        max-width: 680px;
        margin: 0 auto;
        padding: 104px 32px 0;
        border-top: none !important;
        text-align: center;
      }

      .hero::before { display: none; }

      .hero-center {
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      h1 {
        font-family: var(--serif);
        font-size: 48px;
        font-weight: 400;
        letter-spacing: -0.02em;
        line-height: 1.08;
        margin-bottom: 24px;
      }

      .hide-mobile { display: inline; }
      .show-mobile { display: none; }

      .sub {
        font-size: 16px;
        font-weight: 400;
        color: var(--secondary);
        line-height: 1.6;
        margin-bottom: 40px;
        max-width: 480px;
      }

      .hero-actions {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 16px;
      }

      .install-line {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        padding: 10px 16px;
        background: var(--surface);
        border-radius: 2px;
        width: fit-content;
      }

      .install-line code {
        font-family: var(--mono);
        font-size: 13px;
        color: var(--fg);
      }

      .pm-switch {
        font-family: var(--mono);
        font-size: 13px;
        color: var(--accent);
        background: none;
        border: none;
        border-bottom: 1px dashed var(--accent);
        padding: 0;
        cursor: pointer;
        transition: opacity 0.12s;
      }

      .pm-switch:hover { opacity: 0.7; }

      .copy-btn .check-icon { display: none; }
      .copy-btn.copied .copy-icon { display: none; }
      .copy-btn.copied .check-icon { display: block; color: var(--accent); }

      .copy-btn {
        background: none;
        border: none;
        cursor: pointer;
        color: var(--muted);
        padding: 4px;
        border-radius: 2px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: opacity 150ms ease;
      }

      .copy-btn:hover { opacity: 0.6; }
      .copy-btn.copied { color: var(--accent-deep); }

      .ctas {
        display: flex;
        gap: 12px;
        align-items: center;
      }

      .btn-accent {
        display: inline-flex;
        align-items: center;
        padding: 10px 24px;
        background: var(--surface);
        color: var(--fg);
        font-size: 15px;
        font-weight: 400;
        border-radius: 100px;
        border: none;
        text-decoration: none;
        box-shadow: none;
        transition: opacity 150ms ease;
      }

      .btn-accent:hover { opacity: 0.8; }
      .btn-accent:active { transform: scale(0.97); }

      .btn-outline {
        display: inline-flex;
        align-items: center;
        padding: 10px 24px;
        font-size: 15px;
        font-weight: 400;
        color: var(--fg);
        background: transparent;
        border: none;
        border-radius: 100px;
        transition: opacity 150ms ease;
      }

      .btn-outline:hover { opacity: 0.5; }
      .btn-outline:active { transform: scale(0.97); }

      /* DEMO — interactive section below hero */
      .demo {
        max-width: 680px;
        margin: 0 auto;
        padding: 0 32px;
      }

      /* SECTIONS */
      section {
        padding: 80px 0;
        border-top: none;
      }

      section::before {
        content: '';
        display: block;
        width: 80px;
        height: 1px;
        background: var(--border-strong);
        margin: 0 auto 80px;
      }

      .hero::before,
      .demo::before {
        display: none;
      }

      .section-label {
        font-family: var(--mono);
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.06em;
        color: var(--muted);
        margin-bottom: 24px;
      }

      /* LAYERS */
      .layer {
        display: flex;
        gap: 20px;
        padding: 14px 0;
        border-bottom: 1px solid var(--border);
      }

      .layer:last-child { border-bottom: none; }

      .num {
        font-family: var(--mono);
        font-size: 12px;
        color: var(--muted);
        padding-top: 3px;
        flex-shrink: 0;
        width: 24px;
      }

      .layer strong {
        display: block;
        font-family: var(--serif);
        font-size: 16px;
