---
// cerno.sh/benchmark — unlisted. Not linked from nav.
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Benchmark — Cerno vs 007captcha</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="color-scheme" content="light dark" />
    <script is:inline>
      (function(){var s=localStorage.getItem('starlight-theme');var dark=s==='dark'||(!s&&matchMedia('(prefers-color-scheme:dark)').matches);document.documentElement.setAttribute('data-theme',dark?'dark':'light');})();
    </script>
    <style>
      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

      :root, [data-theme='light'] {
        --bg: #ffffff;
        --fg: #282828;
        --secondary: #504944;
        --muted: #6b6866;
        --border: rgba(0,0,0,0.06);
        --border-strong: rgba(0,0,0,0.12);
        --surface: #f3f3f2;
        --accent: #2596be;
        --accent-deep: #1d7898;
        --nav-bg: rgba(255,255,255,0.9);
        --mono: 'Geist Mono', ui-monospace, monospace;
        --sans: 'Geist', ui-sans-serif, system-ui, sans-serif;
        color-scheme: light;
      }

      [data-theme='dark'] {
        --bg: #0d0a09;
        --fg: #f3ece4;
        --secondary: #c5beb5;
        --muted: #978f87;
        --border: rgba(255,245,230,0.08);
        --border-strong: rgba(255,245,230,0.14);
        --surface: #1a1614;
        --accent: #38a9d2;
        --accent-deep: #5bbde0;
        --nav-bg: rgba(13,10,9,0.9);
        color-scheme: dark;
      }

      html { -webkit-font-smoothing: antialiased; }

      body {
        font-family: var(--sans);
        background: var(--bg);
        color: var(--fg);
        line-height: 1.5;
        font-size: 15px;
        letter-spacing: -0.011em;
      }

      a { color: inherit; text-decoration: none; }

      nav {
        position: sticky;
        top: 0;
        z-index: 100;
        background: var(--nav-bg);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
      }

      .nav-inner {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 32px;
        height: 56px;
      }

      .logo {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: var(--mono);
        font-weight: 500;
        font-size: 15px;
        letter-spacing: -0.02em;
      }

      .logo-mark { width: 20px; height: 20px; flex-shrink: 0; }

      .nav-r { display: flex; gap: 20px; font-size: 14px; color: var(--muted); align-items: center; }
      .nav-r a { transition: color 0.15s; }
      .nav-r a:hover { color: var(--fg); }

      .theme-toggle {
        background: none; border: none; cursor: pointer; color: var(--muted);
        padding: 4px; display: inline-flex; align-items: center; transition: color 0.15s;
      }
      .theme-toggle:hover { color: var(--fg); }
      .icon-sun, .icon-moon, .icon-auto { width: 16px; height: 16px; }
      [data-mode='light'] .icon-moon, [data-mode='light'] .icon-auto,
      [data-mode='dark'] .icon-sun, [data-mode='dark'] .icon-auto,
      [data-mode='auto'] .icon-sun, [data-mode='auto'] .icon-moon { display: none; }

      main {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 32px 80px;
      }

      .page-header {
        padding: 48px 0 36px;
        border-bottom: 1px solid var(--border);
        margin-bottom: 36px;
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
      }

      .page-header h1 {
        font-size: 22px;
        font-weight: 500;
        letter-spacing: -0.02em;
      }

      .page-header p {
        font-size: 13px;
        color: var(--muted);
        font-family: var(--mono);
      }

      .bench-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        align-items: start;
      }

      @media (max-width: 820px) {
        .bench-grid { grid-template-columns: 1fr; }
      }

      .panel {
        border: 1px solid var(--border-strong);
        border-radius: 3px;
        overflow: hidden;
      }

      .panel-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 16px;
        border-bottom: 1px solid var(--border);
        background: var(--surface);
        gap: 12px;
      }

      .panel-title {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 13px;
        font-weight: 500;
        font-family: var(--mono);
        white-space: nowrap;
      }

      .panel-title a {
        font-size: 11px;
        color: var(--muted);
        transition: color 0.15s;
      }
      .panel-title a:hover { color: var(--accent); }

      .panel-meta {
        display: flex;
        align-items: center;
        gap: 6px;
        font-family: var(--mono);
        font-size: 12px;
        color: var(--muted);
        flex-shrink: 0;
      }

      .panel-meta .sep { opacity: 0.4; }

      .status-text { transition: color 0.2s; }

      .panel-body {
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 12px;
      }

      .panel-body canvas {
        width: 100%;
        display: block;
        border-radius: 2px;
        cursor: crosshair;
      }

      .panel-foot {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .panel-score {
        font-family: var(--mono);
        font-size: 12px;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .score-val { color: var(--fg); }
      .score-val.pass { color: #16a34a; }
      .score-val.fail { color: #dc2626; }

      .btn-reset {
        font-family: var(--mono);
        font-size: 12px;
        color: var(--muted);
        background: transparent;
        border: 1px solid var(--border-strong);
        border-radius: 2px;
        padding: 5px 12px;
        cursor: pointer;
        transition: color 0.15s, border-color 0.15s;
      }
      .btn-reset:hover { color: var(--fg); border-color: var(--fg); }

      .note {
        font-size: 11px;
        font-family: var(--mono);
        color: var(--muted);
        padding: 8px 0 0;
        line-height: 1.6;
        border-top: 1px solid var(--border);
        margin-top: 4px;
      }
    </style>
  </head>

  <body>
    <nav>
