            <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            <svg class="icon-auto" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </button>
        </div>
      </div>
    </nav>

    <main>
      <div class="page-header">
        <h1>Benchmark</h1>
        <p>Cerno maze &nbsp;·&nbsp; 007captcha ball &nbsp;·&nbsp; complete each, compare</p>
      </div>

      <div class="bench-grid">

        <!-- ── Cerno ── -->
        <div class="panel">
          <div class="panel-head">
            <div class="panel-title">
              Cerno
              <a href="https://github.com/PlawIO/cerno" target="_blank" rel="noopener">GitHub ↗</a>
            </div>
            <div class="panel-meta">
              <span id="cerno-elapsed">-</span>
              <span class="sep">·</span>
              <span class="status-text" id="cerno-status">Not started</span>
            </div>
          </div>
          <div class="panel-body">
            <canvas id="cerno-canvas"></canvas>
            <div class="panel-foot">
              <div class="panel-score">
                Score
                <span class="score-val" id="cerno-score">-</span>
              </div>
              <button class="btn-reset" id="cerno-reset">New maze</button>
            </div>
            <p class="note">Live API &nbsp;·&nbsp; maze-trace + motor-control analysis + server-side behavioral scoring</p>
          </div>
        </div>

        <!-- ── 007captcha ball ── -->
        <div class="panel">
          <div class="panel-head">
            <div class="panel-title">
              007captcha &nbsp;·&nbsp; ball
              <a href="https://github.com/mutkuoz/007captcha" target="_blank" rel="noopener">GitHub ↗</a>
            </div>
            <div class="panel-meta">
              <span id="ball-elapsed">-</span>
              <span class="sep">·</span>
              <span class="status-text" id="ball-status">Not started</span>
            </div>
          </div>
          <div class="panel-body">
            <canvas id="ball-canvas"></canvas>
            <div class="panel-foot">
              <div class="panel-score">
                Avg deviation
                <span class="score-val" id="ball-score">-</span>
              </div>
              <button class="btn-reset" id="ball-reset">New challenge</button>
            </div>
            <p class="note">Client-side simulation of 007captcha ball mechanic &nbsp;·&nbsp; 8s follow-the-ball challenge &nbsp;·&nbsp; color changes every 2s</p>
          </div>
        </div>

      </div>
    </main>

    <script>
      document.addEventListener('DOMContentLoaded', function() {

        // ════════════════════════════════════════════════════════
        // SHARED UTILITIES
        // ════════════════════════════════════════════════════════

        function mulberry32(seed) {
          var s = seed | 0;
          return function() {
            s = (s + 0x6d2b79f5) | 0;
            var t = Math.imul(s ^ (s >>> 15), 1 | s);
            t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
            return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
          };
        }

        function isDark() {
          return document.documentElement.getAttribute('data-theme') === 'dark';
        }

        // ════════════════════════════════════════════════════════
        // CERNO MAZE
        // Exact algorithm from @cernosh/core + live API
        // ════════════════════════════════════════════════════════

        var C_API = 'https://api.cerno.sh';
        var C_KEY = 'ck_05a716da870416d96af00ef30d7808f0';
        var C_SID = 'bench-' + Math.random().toString(36).slice(2) + Date.now().toString(36);

        // Wall bitmask
        var W_N = 1, W_S = 2, W_E = 4, W_W = 8;
        var DIRS = [W_N, W_S, W_E, W_W];
        var DX = {}; DX[W_N]=0; DX[W_S]=0; DX[W_E]=1; DX[W_W]=-1;
        var DY = {}; DY[W_N]=-1; DY[W_S]=1; DY[W_E]=0; DY[W_W]=0;
        var OPP = {}; OPP[W_N]=W_S; OPP[W_S]=W_N; OPP[W_E]=W_W; OPP[W_W]=W_E;

        var C_MW, C_MH, C_CELL = 40, C_MARGIN = 20, C_TEXT_H = 24;
        var cMaze = null, cDrag = null, cCompleted = false;
        var cLogW, cLogH;
        var cRawEvents = [], cChallenge = null, cPow = null;
        var cKeyPair = null;
        var cTimerStart = null, cTimerIv = null;

        var cernoCanvas = document.getElementById('cerno-canvas');
        var cernoCtx = cernoCanvas.getContext('2d');

        function cElapsed(el) { document.getElementById('cerno-elapsed').textContent = el; }
        function cStatus(txt, color) {
          var el = document.getElementById('cerno-status');
          el.textContent = txt;
          el.style.color = color || '';
        }
        function cScore(txt, cls) {
          var el = document.getElementById('cerno-score');
          el.textContent = txt;
          el.className = 'score-val' + (cls ? ' ' + cls : '');
        }

        function cStartTimer() {
          cTimerStart = Date.now();
          cTimerIv = setInterval(function() {
            if (cTimerStart) {
              var ms = Date.now() - cTimerStart;
              cElapsed((ms / 1000).toFixed(1) + 's');
            }
          }, 100);
        }

        function cStopTimer() {
          clearInterval(cTimerIv);
          cTimerIv = null;
        }

        // Maze gen (Growing Tree — exact from @cernosh/core)
        function cShuffled(arr, rand) {
          var a = arr.slice();
          for (var i = a.length - 1; i > 0; i--) {
            var j = Math.floor(rand() * (i + 1));
            var tmp = a[i]; a[i] = a[j]; a[j] = tmp;
          }
          return a;
        }

        function cSolveMaze(grid, start, exit) {
          var vis = [], par = new Map();
          for (var y = 0; y < C_MH; y++) { vis[y] = []; for (var x = 0; x < C_MW; x++) vis[y][x] = false; }
          var queue = [start], head = 0;
          vis[start.y][start.x] = true;
          par.set(start.x + ',' + start.y, null);
          while (head < queue.length) {
            var c = queue[head++];
            if (c.x === exit.x && c.y === exit.y) {
              var path = [], node = c;
              while (node !== null) { path.unshift({ x: node.x, y: node.y }); node = par.get(node.x + ',' + node.y); }
              return path;
            }
            var cell = grid[c.y][c.x];
            for (var di = 0; di < DIRS.length; di++) {
              if (cell.walls & DIRS[di]) continue;
              var nx = c.x + DX[DIRS[di]], ny = c.y + DY[DIRS[di]];
              if (nx >= 0 && nx < C_MW && ny >= 0 && ny < C_MH && !vis[ny][nx]) {
                vis[ny][nx] = true; par.set(nx + ',' + ny, c); queue.push({ x: nx, y: ny });
              }
            }
          }
          return [start, exit];
        }

        function cGenMaze(seed, width, height, diff) {
          C_MW = width; C_MH = height;
          var rand = mulberry32(seed);
          var grid = [];
          for (var y = 0; y < C_MH; y++) {
            grid[y] = [];
            for (var x = 0; x < C_MW; x++) grid[y][x] = { x: x, y: y, walls: W_N|W_S|W_E|W_W };
          }
          var visited = [];
          for (var y2 = 0; y2 < C_MH; y2++) { visited[y2] = []; for (var x2 = 0; x2 < C_MW; x2++) visited[y2][x2] = false; }
          var active = [];
          var sx = Math.floor(rand() * C_MW), sy = Math.floor(rand() * C_MH);
          active.push({ x: sx, y: sy }); visited[sy][sx] = true;
          while (active.length > 0) {
            var idx = rand() < diff ? Math.floor(rand() * active.length) : active.length - 1;
            var cur = active[idx];
            var dirs = cShuffled(DIRS, rand); var carved = false;
            for (var di2 = 0; di2 < dirs.length; di2++) {
              var dir = dirs[di2];
              var nx2 = cur.x + DX[dir], ny2 = cur.y + DY[dir];
              if (nx2 >= 0 && nx2 < C_MW && ny2 >= 0 && ny2 < C_MH && !visited[ny2][nx2]) {
                grid[cur.y][cur.x].walls &= ~dir;
                grid[ny2][nx2].walls &= ~OPP[dir];
                visited[ny2][nx2] = true; active.push({ x: nx2, y: ny2 }); carved = true; break;
              }
            }
            if (!carved) active.splice(idx, 1);
          }
          var start = { x: 0, y: 0 }, exit = { x: C_MW - 1, y: C_MH - 1 };
          return { grid: grid, start: start, exit: exit, seed: seed };
        }

        function cRecalc() {
          cLogW = C_MW * C_CELL + C_MARGIN * 2;
          cLogH = C_MH * C_CELL + C_MARGIN * 2 + C_TEXT_H;
        }

        function cResize() {
          var dpr = window.devicePixelRatio || 1;
          var dispW = cernoCanvas.clientWidth;
          var scaleX = dispW / cLogW;
          cernoCanvas.width = dispW * dpr;
          cernoCanvas.height = (cLogH * scaleX) * dpr;
          cernoCanvas.style.height = (cLogH * scaleX) + 'px';
          cernoCtx.setTransform(dpr * scaleX, 0, 0, dpr * scaleX, 0, 0);
        }

        function cCellCenter(cx, cy) {
          return { px: C_MARGIN + cx * C_CELL + C_CELL / 2, py: C_MARGIN + cy * C_CELL + C_CELL / 2 };
        }

        function cPxToCell(px, py) {
          var cx = Math.floor((px - C_MARGIN) / C_CELL);
          var cy = Math.floor((py - C_MARGIN) / C_CELL);
          if (cx < 0 || cx >= C_MW || cy < 0 || cy >= C_MH) return null;
          return { x: cx, y: cy };
        }

        function cCanPass(fx, fy, tx, ty) {
          var dx = tx - fx, dy = ty - fy;
          if (Math.abs(dx) + Math.abs(dy) !== 1) return false;
          var dir;
          if (dx === 1) dir = W_E; else if (dx === -1) dir = W_W;
          else if (dy === 1) dir = W_S; else dir = W_N;
          return !(cMaze.grid[fy][fx].walls & dir);
        }

        function cDraw() {
          if (!cMaze) return;
          cResize();
          var dark = isDark();
          cernoCtx.fillStyle = dark ? '#0f172a' : '#f8fafc';
          cernoCtx.fillRect(0, 0, cLogW, cLogH);

          cernoCtx.fillStyle = dark ? '#94a3b8' : '#64748b';
          cernoCtx.font = '13px system-ui, -apple-system, sans-serif';
          cernoCtx.textAlign = 'center';
          cernoCtx.fillText('Trace the path from green to red', cLogW / 2, cLogH - 8);

          cernoCtx.strokeStyle = dark ? '#cbd5e1' : '#1e293b';
          cernoCtx.lineWidth = 2;
          cernoCtx.lineCap = 'round';
          for (var y = 0; y < C_MH; y++) {
            for (var x = 0; x < C_MW; x++) {
              var c = cMaze.grid[y][x];
              var px = C_MARGIN + x * C_CELL, py = C_MARGIN + y * C_CELL;
              if (c.walls & W_N) { cernoCtx.beginPath(); cernoCtx.moveTo(px, py); cernoCtx.lineTo(px + C_CELL, py); cernoCtx.stroke(); }
              if (c.walls & W_S) { cernoCtx.beginPath(); cernoCtx.moveTo(px, py + C_CELL); cernoCtx.lineTo(px + C_CELL, py + C_CELL); cernoCtx.stroke(); }
              if (c.walls & W_W) { cernoCtx.beginPath(); cernoCtx.moveTo(px, py); cernoCtx.lineTo(px, py + C_CELL); cernoCtx.stroke(); }
              if (c.walls & W_E) { cernoCtx.beginPath(); cernoCtx.moveTo(px + C_CELL, py); cernoCtx.lineTo(px + C_CELL, py + C_CELL); cernoCtx.stroke(); }
            }
          }

          // Start (green) / exit (red) markers
          var sc = cCellCenter(cMaze.start.x, cMaze.start.y);
          cernoCtx.fillStyle = '#22c55e';
          cernoCtx.beginPath(); cernoCtx.arc(sc.px, sc.py, 12 * (C_CELL / 40), 0, Math.PI * 2); cernoCtx.fill();

          var ec = cCellCenter(cMaze.exit.x, cMaze.exit.y);
          cernoCtx.fillStyle = '#ef4444';
          cernoCtx.beginPath(); cernoCtx.arc(ec.px, ec.py, 12 * (C_CELL / 40), 0, Math.PI * 2); cernoCtx.fill();

          // Trace
          if (cDrag && cDrag.path.length > 1) {
            cernoCtx.strokeStyle = '#3b82f6';
            cernoCtx.lineWidth = 3;
            cernoCtx.lineJoin = 'round'; cernoCtx.lineCap = 'round';
            cernoCtx.beginPath();
            var fp = cCellCenter(cDrag.path[0].x, cDrag.path[0].y);
            cernoCtx.moveTo(fp.px, fp.py);
            for (var i = 1; i < cDrag.path.length; i++) {
              var pt = cCellCenter(cDrag.path[i].x, cDrag.path[i].y);
              cernoCtx.lineTo(pt.px, pt.py);
            }
            cernoCtx.stroke();
          }
        }

        // PoW solver (Web Worker)
        function cStartPow(challenge, difficulty) {
          var cancelled = false;
          var cancelFn = function() { cancelled = true; };
          var promise = new Promise(function(resolve, reject) {
            try {
              var wc = 'const ctx=self;function h(b,bits){const v=new Uint8Array(b);let r=bits;for(let i=0;i<v.length&&r>0;i++){if(r>=8){if(v[i]!==0)return false;r-=8}else{if((v[i]&(255<<(8-r)))!==0)return false;r=0}}return true}function t(b){const a=new Uint8Array(b);let s="";for(let i=0;i<a.length;i++)s+=a[i].toString(16).padStart(2,"0");return s}const e=new TextEncoder();async function solve(c,d){let n=0;while(n<10000000){for(let i=0;i<1000&&n<10000000;i++){const hash=await crypto.subtle.digest("SHA-256",e.encode(c+n));if(h(hash,d)){ctx.postMessage({nonce:n,hash:t(hash)});return}n++}await new Promise(r=>setTimeout(r,0))}}ctx.addEventListener("message",e2=>{solve(e2.data.c,e2.data.d)})';
              var blob = new Blob([wc], { type: 'application/javascript' });
              var url = URL.createObjectURL(blob);
              var worker = new Worker(url);
              worker.onmessage = function(e) { URL.revokeObjectURL(url); if (!cancelled) resolve(e.data); };
              worker.onerror = function() { URL.revokeObjectURL(url); worker.terminate(); fallback(); };
              worker.postMessage({ c: challenge, d: difficulty });
              cancelFn = function() { cancelled = true; worker.terminate(); };
            } catch (_) { fallback(); }
            async function fallback() {
              var enc = new TextEncoder(); var nonce = 0;
              while (nonce < 10000000) {
                if (cancelled) { reject(new Error('cancelled')); return; }
                for (var i = 0; i < 500 && nonce < 10000000; i++) {
                  var hash = await crypto.subtle.digest('SHA-256', enc.encode(challenge + nonce));
                  var view = new Uint8Array(hash); var rem = difficulty; var ok = true;
                  for (var j = 0; j < view.length && rem > 0; j++) {
                    if (rem >= 8) { if (view[j] !== 0) { ok = false; break; } rem -= 8; }
                    else { if ((view[j] & (0xff << (8 - rem))) !== 0) { ok = false; break; } rem = 0; }
                  }
                  if (ok) { resolve({ nonce: nonce, hash: Array.from(new Uint8Array(hash)).map(function(b){return b.toString(16).padStart(2,'0');}).join('') }); return; }
                  nonce++;
                }
                await new Promise(function(r) { setTimeout(r, 0); });
              }
              reject(new Error('PoW max iter'));
            }
          });
          promise.cancel = cancelFn;
          return promise;
        }

        // ECDSA keypair
        async function cGenKeyPair() {
          var kp = await crypto.subtle.generateKey({ name: 'ECDSA', namedCurve: 'P-256' }, true, ['sign', 'verify']);
          var jwk = await crypto.subtle.exportKey('jwk', kp.publicKey);
          return { publicKeyBase64: btoa(JSON.stringify(jwk)), privateKey: kp.privateKey };
        }

        async function cSignBinding(payload, privateKey) {
          var sig = await crypto.subtle.sign({ name: 'ECDSA', hash: 'SHA-256' }, privateKey, new TextEncoder().encode(payload));
          var bytes = new Uint8Array(sig); var binary = '';
          for (var i = 0; i < bytes.length; i++) binary += String.fromCharCode(bytes[i]);
          return btoa(binary);
        }

        // Pointer events
        function cCanvasCoords(e) {
          var rect = cernoCanvas.getBoundingClientRect();
          return { px: (e.clientX - rect.left) * (cLogW / rect.width), py: (e.clientY - rect.top) * (cLogH / rect.height) };
        }

        function cPtrType(e) {
          var pt = e.pointerType;
          return (pt === 'mouse' || pt === 'touch' || pt === 'pen') ? pt : 'mouse';
        }

        cernoCanvas.addEventListener('pointerdown', function(e) {
          if (cCompleted || !cMaze) return;
          var coords = cCanvasCoords(e);
          var cell = cPxToCell(coords.px, coords.py);
          if (!cell || cell.x !== cMaze.start.x || cell.y !== cMaze.start.y) return;
          cernoCanvas.setPointerCapture(e.pointerId);
          cDrag = { dragging: true, path: [{ x: cell.x, y: cell.y }], visited: new Set([cell.x + ',' + cell.y]), current: cell };
          cRawEvents = [{ x: coords.px / cLogW, y: coords.py / cLogH, t: performance.now(), type: 'down', pointer_type: cPtrType(e) }];
          cStartTimer();
          cStatus('Tracing...');
          cDraw();
        });

        cernoCanvas.addEventListener('pointermove', function(e) {
          if (!cDrag || !cDrag.dragging || cCompleted) return;
          var coords = cCanvasCoords(e);
          var now = performance.now();
          cRawEvents.push({ x: coords.px / cLogW, y: coords.py / cLogH, t: now, type: 'move', pointer_type: cPtrType(e) });
          var cell = cPxToCell(coords.px, coords.py);
          if (!cell || !cDrag.current) return;
          if (cell.x === cDrag.current.x && cell.y === cDrag.current.y) return;
          if (!cCanPass(cDrag.current.x, cDrag.current.y, cell.x, cell.y)) return;
          var key = cell.x + ',' + cell.y;
          if (cDrag.path.length >= 2) {
            var prev = cDrag.path[cDrag.path.length - 2];
            if (prev.x === cell.x && prev.y === cell.y) {
              var removed = cDrag.path.pop(); cDrag.visited.delete(removed.x + ',' + removed.y);
              cDrag.current = cell; cDraw(); return;
            }
          }
          if (cDrag.visited.has(key)) return;
          cDrag.path.push({ x: cell.x, y: cell.y }); cDrag.visited.add(key); cDrag.current = cell; cDraw();
          if (cell.x === cMaze.exit.x && cell.y === cMaze.exit.y) {
            cCompleted = true; cDrag.dragging = false;
            cRawEvents.push({ x: coords.px / cLogW, y: coords.py / cLogH, t: performance.now(), type: 'up', pointer_type: cPtrType(e) });
            cStopTimer();
            cSubmit();
          }
        });

        cernoCanvas.addEventListener('pointerup', function() {
          if (!cDrag || !cDrag.dragging) return;
          cDrag.dragging = false; cDrag.path = []; cDrag.visited = new Set(); cDrag.current = null;
          cRawEvents = []; cDraw();
          if (cTimerIv) { cStopTimer(); cElapsed('-'); }
        });

        async function cSubmit() {
          if (!cChallenge) {
            cStatus('Local score only (no API)', '#f59e0b');
            return;
          }
          cStatus('Verifying...');
          try {
            var pow = await cPow;
            var binding = cChallenge.id + ':' + cChallenge.site_key + ':' + cChallenge.expires_at;
            var signature = await cSignBinding(binding, cKeyPair.privateKey);
            var res = await fetch(C_API + '/verify', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                challenge_id: cChallenge.id,
                site_key: C_KEY,
                session_id: C_SID,
                events: cRawEvents,
                pow_proof: pow,
                public_key: cKeyPair.publicKeyBase64,
                signature: signature,
                timestamp: Date.now()
              })
            });
            var result = await res.json();
            if (result.success) {
              var s = result.score != null ? (result.score * 100).toFixed(0) + '%' : '✓';
              cScore(s, 'pass');
              cStatus('Pass', '#16a34a');
            } else {
              var code = result.error_code || 'rejected';
              cScore('✗', 'fail');
              cStatus(code === 'behavioral_rejected' ? 'Bot pattern' : code.replace(/_/g, ' '), '#dc2626');
            }
          } catch (err) {
            cStatus('Connection error', '#dc2626');
          }
        }

        async function cFetch() {
          cStatus('Loading...');
          cScore('-');
          cDrag = null; cCompleted = false; cRawEvents = [];
          cStopTimer(); cElapsed('-');
          if (cPow && cPow.cancel) cPow.cancel();
          try {
            if (!cKeyPair) cKeyPair = await cGenKeyPair();
            var res = await fetch(C_API + '/challenge', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ site_key: C_KEY, public_key: cKeyPair.publicKeyBase64 })
            });
            if (!res.ok) throw new Error('HTTP ' + res.status);
            cChallenge = await res.json();
            C_CELL = cChallenge.cell_size || 40;
            cMaze = cGenMaze(cChallenge.maze_seed, cChallenge.maze_width, cChallenge.maze_height, cChallenge.maze_difficulty);
            cRecalc();
            cPow = cStartPow(cChallenge.pow_challenge, cChallenge.pow_difficulty);
            cStatus('Trace from green to red');
            cDraw();
          } catch (err) {
            console.warn('Cerno API unavailable, local fallback:', err.message);
            cChallenge = null;
            C_CELL = 40;
            var seed = (Date.now() ^ (Math.random() * 0xFFFFFFFF)) >>> 0;
            cMaze = cGenMaze(seed, 7, 7, 0.3);
            cRecalc(); cDraw();
            cStatus('Trace from green to red (offline)');
          }
        }

        document.getElementById('cerno-reset').addEventListener('click', function() {
          C_SID = 'bench-' + Math.random().toString(36).slice(2) + Date.now().toString(36);
          cFetch();
        });

        window.addEventListener('resize', function() { cDraw(); });

        cFetch();

        // ════════════════════════════════════════════════════════
        // 007CAPTCHA BALL CHALLENGE
        // Client-side simulation of the ball-tracking mechanic:
        // - Ball moves along random waypoints for 8 seconds
        // - Colors change every 2 seconds (like 007captcha)
        // - User must keep cursor close to ball
        // - Scored on average deviation from ball center
        // ════════════════════════════════════════════════════════

        var BW = 480, BH = 360;
        var B_RADIUS = 20;
        var B_DURATION = 8000;
        var B_SEGMENT = 1800;      // ms per waypoint segment
        var B_PASS_DEV = 55;       // avg-deviation threshold (px on 480-wide canvas)

        var B_COLORS = ['#2596be', '#22c55e', '#f59e0b', '#e87b85', '#a78bfa', '#f97316'];

        var bCanvas = document.getElementById('ball-canvas');
        var bCtx = bCanvas.getContext('2d');
        bCanvas.width = BW;
        bCanvas.height = BH;

        var bRunning = false, bDone = false;
        var bStartTime = null, bStartWall = null;
        var bMX = -1, bMY = -1;
        var bDeviations = [];
        var bFrameId = null;
        var bWaypoints = [];
        var bColorIdx = 0, bLastColor = 0;

        function bElapsed(txt) { document.getElementById('ball-elapsed').textContent = txt; }
        function bStatus(txt, color) {
          var el = document.getElementById('ball-status');
          el.textContent = txt; el.style.color = color || '';
        }
        function bScore(txt, cls) {
          var el = document.getElementById('ball-score');
          el.textContent = txt;
          el.className = 'score-val' + (cls ? ' ' + cls : '');
        }

        function bGenWaypoints() {
          var MARGIN = 70;
          var count = Math.ceil(B_DURATION / B_SEGMENT) + 3;
          var rand = mulberry32((Date.now() ^ (Math.random() * 0xFFFFFFFF)) >>> 0);
          bWaypoints = [{ x: BW / 2, y: BH / 2 }];
          for (var i = 1; i < count; i++) {
            bWaypoints.push({
              x: MARGIN + rand() * (BW - MARGIN * 2),
              y: MARGIN + rand() * (BH - MARGIN * 2)
            });
          }
        }

        function bGetPos(elapsed) {
          var segIdx = Math.floor(elapsed / B_SEGMENT);
          var segT = (elapsed % B_SEGMENT) / B_SEGMENT;
          var from = bWaypoints[Math.min(segIdx, bWaypoints.length - 2)];
          var to = bWaypoints[Math.min(segIdx + 1, bWaypoints.length - 1)];
          // Ease in-out cubic
          var t = segT < 0.5 ? 4 * segT * segT * segT : 1 - Math.pow(-2 * segT + 2, 3) / 2;
          return { x: from.x + (to.x - from.x) * t, y: from.y + (to.y - from.y) * t };
        }

        function bStart() {
          bRunning = true; bDone = false;
          bStartTime = performance.now();
          bStartWall = Date.now();
          bDeviations = [];
          bColorIdx = 0; bLastColor = bStartTime;
          bStatus('Tracking...');
          requestAnimationFrame(function(now) { bFrame(now); });
        }

        function bFrame(now) {
          if (!bRunning) return;
          var elapsed = now - bStartTime;

          if (elapsed >= B_DURATION) { bFinish(); return; }

          // Color change every 2 seconds
          if (now - bLastColor > 2000) {
            bColorIdx = (bColorIdx + 1) % B_COLORS.length;
            bLastColor = now;
          }

          var pos = bGetPos(elapsed);

          // Record deviation when mouse is engaged
          if (bMX >= 0) {
            var dx = pos.x - bMX, dy = pos.y - bMY;
            bDeviations.push(Math.sqrt(dx * dx + dy * dy));
          }

          bDraw(pos, elapsed);
          bElapsed((elapsed / 1000).toFixed(1) + 's / 8s');

          bFrameId = requestAnimationFrame(function(t) { bFrame(t); });
        }

        function bDraw(pos, elapsed) {
          var ctx = bCtx;
          var dark = isDark();
          var color = B_COLORS[bColorIdx];

          // Background
          ctx.fillStyle = dark ? '#0f172a' : '#f0f4f8';
          ctx.fillRect(0, 0, BW, BH);

          // Subtle dot grid
          ctx.fillStyle = dark ? 'rgba(255,255,255,0.025)' : 'rgba(0,0,0,0.025)';
          for (var gx = 24; gx < BW; gx += 24) {
            for (var gy = 24; gy < BH - 4; gy += 24) {
              ctx.fillRect(gx, gy, 1.5, 1.5);
            }
          }

          // Ball glow
          var grd = ctx.createRadialGradient(pos.x, pos.y, 0, pos.x, pos.y, B_RADIUS * 2.8);
          grd.addColorStop(0, color + '50');
          grd.addColorStop(1, 'transparent');
          ctx.fillStyle = grd;
          ctx.beginPath(); ctx.arc(pos.x, pos.y, B_RADIUS * 2.8, 0, Math.PI * 2); ctx.fill();

          // Ball body
          ctx.fillStyle = color;
          ctx.beginPath(); ctx.arc(pos.x, pos.y, B_RADIUS, 0, Math.PI * 2); ctx.fill();

          // Specular
          ctx.fillStyle = 'rgba(255,255,255,0.35)';
          ctx.beginPath(); ctx.arc(pos.x - B_RADIUS * 0.28, pos.y - B_RADIUS * 0.28, B_RADIUS * 0.38, 0, Math.PI * 2); ctx.fill();

          // Cursor ring (green/yellow/red based on distance)
          if (bMX >= 0) {
            var d = Math.sqrt((pos.x - bMX) * (pos.x - bMX) + (pos.y - bMY) * (pos.y - bMY));
            var ringColor = d < 30 ? '#22c55e' : d < 70 ? '#f59e0b' : '#ef4444';
            ctx.strokeStyle = ringColor + 'cc';
            ctx.lineWidth = 1.5;
            ctx.beginPath(); ctx.arc(bMX, bMY, 9, 0, Math.PI * 2); ctx.stroke();
            // Crosshair
            ctx.strokeStyle = ringColor + '60';
            ctx.lineWidth = 1;
            ctx.beginPath();
            ctx.moveTo(bMX - 14, bMY); ctx.lineTo(bMX + 14, bMY);
            ctx.moveTo(bMX, bMY - 14); ctx.lineTo(bMX, bMY + 14);
            ctx.stroke();
          }

          // Progress bar
          var prog = elapsed / B_DURATION;
          ctx.fillStyle = dark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.06)';
          ctx.fillRect(0, BH - 3, BW, 3);
          ctx.fillStyle = color;
          ctx.fillRect(0, BH - 3, BW * prog, 3);

          // Fade-in instruction
          if (elapsed < 1400) {
            ctx.globalAlpha = Math.max(0, 1 - elapsed / 1400);
            ctx.fillStyle = dark ? '#94a3b8' : '#64748b';
            ctx.font = '12px system-ui, sans-serif';
            ctx.textAlign = 'center';
            ctx.fillText('Follow the ball · colors change every 2s', BW / 2, 18);
            ctx.globalAlpha = 1;
          }
        }

        function bDrawIdle() {
          var ctx = bCtx;
          var dark = isDark();
          ctx.fillStyle = dark ? '#0f172a' : '#f0f4f8';
          ctx.fillRect(0, 0, BW, BH);

          ctx.fillStyle = dark ? 'rgba(255,255,255,0.025)' : 'rgba(0,0,0,0.025)';
          for (var gx = 24; gx < BW; gx += 24) {
            for (var gy = 24; gy < BH - 4; gy += 24) { ctx.fillRect(gx, gy, 1.5, 1.5); }
          }

          var cx = BW / 2, cy = BH / 2;
          ctx.fillStyle = '#2596be';
          ctx.beginPath(); ctx.arc(cx, cy, B_RADIUS, 0, Math.PI * 2); ctx.fill();
          ctx.fillStyle = 'rgba(255,255,255,0.35)';
          ctx.beginPath(); ctx.arc(cx - B_RADIUS * 0.28, cy - B_RADIUS * 0.28, B_RADIUS * 0.38, 0, Math.PI * 2); ctx.fill();

          ctx.fillStyle = dark ? '#94a3b8' : '#64748b';
          ctx.font = '13px system-ui, sans-serif';
          ctx.textAlign = 'center';
          ctx.fillText('Move cursor over canvas to begin', BW / 2, BH - 14);
        }

        function bFinish() {
          bRunning = false; bDone = true;
          if (bFrameId) cancelAnimationFrame(bFrameId);

          var avgDev = bDeviations.length > 0
            ? bDeviations.reduce(function(a, b) { return a + b; }, 0) / bDeviations.length
            : 999;
          var maxDev = bDeviations.length > 0
            ? Math.max.apply(null, bDeviations)
            : 999;

          var passed = avgDev < B_PASS_DEV;
          var elapsed = Date.now() - bStartWall;

          bScore(avgDev.toFixed(0) + 'px', passed ? 'pass' : 'fail');
          bStatus(passed ? 'Pass' : 'Fail', passed ? '#16a34a' : '#dc2626');
          bElapsed((elapsed / 1000).toFixed(1) + 's');

          // Result overlay
          var ctx = bCtx;
          var dark = isDark();
          ctx.fillStyle = dark ? 'rgba(15,23,42,0.88)' : 'rgba(240,244,248,0.88)';
          ctx.fillRect(0, 0, BW, BH);

          ctx.fillStyle = passed ? '#22c55e' : '#ef4444';
          ctx.font = '600 22px system-ui, sans-serif';
          ctx.textAlign = 'center';
          ctx.fillText(passed ? 'Followed — Pass' : 'Lost track — Fail', BW / 2, BH / 2 - 22);

          ctx.fillStyle = dark ? '#94a3b8' : '#64748b';
          ctx.font = '13px system-ui, sans-serif';
          ctx.fillText('Avg deviation: ' + avgDev.toFixed(1) + 'px  (threshold: ' + B_PASS_DEV + 'px)', BW / 2, BH / 2 + 6);
          ctx.fillText('Max deviation: ' + maxDev.toFixed(1) + 'px  ·  Samples: ' + bDeviations.length, BW / 2, BH / 2 + 26);
        }

        function bReset() {
          if (bFrameId) cancelAnimationFrame(bFrameId);
          bRunning = false; bDone = false;
          bStartTime = null; bMX = -1; bMY = -1;
          bDeviations = []; bColorIdx = 0; bLastColor = 0;
          bStatus('Not started'); bStatus('Not started', '');
          bScore('-'); bElapsed('-');
          bGenWaypoints();
          bDrawIdle();
        }

        bCanvas.addEventListener('mousemove', function(e) {
          var rect = bCanvas.getBoundingClientRect();
          bMX = (e.clientX - rect.left) * (BW / rect.width);
          bMY = (e.clientY - rect.top) * (BH / rect.height);
          if (!bRunning && !bDone) bStart();
        });

        bCanvas.addEventListener('touchmove', function(e) {
          e.preventDefault();
          var rect = bCanvas.getBoundingClientRect();
          var touch = e.touches[0];
          bMX = (touch.clientX - rect.left) * (BW / rect.width);
          bMY = (touch.clientY - rect.top) * (BH / rect.height);
          if (!bRunning && !bDone) bStart();
        }, { passive: false });

        document.getElementById('ball-reset').addEventListener('click', function() { bReset(); });

        bGenWaypoints();
        bDrawIdle();

        // ════════════════════════════════════════════════════════
        // THEME TOGGLE
        // ════════════════════════════════════════════════════════

        var themeBtn = document.getElementById('theme-toggle');
        var themeModes = ['auto', 'light', 'dark'];
        var stored = localStorage.getItem('starlight-theme');
        var currentMode = (stored === 'light' || stored === 'dark') ? stored : 'auto';

        function applyTheme(mode) {
          currentMode = mode;
          themeBtn.setAttribute('data-mode', mode);
          var dark;
          if (mode === 'auto') { dark = matchMedia('(prefers-color-scheme:dark)').matches; localStorage.removeItem('starlight-theme'); }
          else { dark = mode === 'dark'; localStorage.setItem('starlight-theme', mode); }
          document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light');
          if (cMaze) cDraw();
          if (!bRunning) bDrawIdle();
        }

        themeBtn.setAttribute('data-mode', currentMode);
        themeBtn.addEventListener('click', function() {
          applyTheme(themeModes[(themeModes.indexOf(currentMode) + 1) % themeModes.length]);
        });
        matchMedia('(prefers-color-scheme:dark)').addEventListener('change', function() {
          if (currentMode === 'auto') applyTheme('auto');
        });

      });
    </script>
  </body>
</html>
