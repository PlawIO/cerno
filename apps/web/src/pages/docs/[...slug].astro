---
import fs from 'node:fs'
import path from 'node:path'

export async function getStaticPaths() {
  const docsRoot = path.resolve('public/docs')
  if (!fs.existsSync(docsRoot)) return []

  const collectDocSlugs = (root: string, current = ''): string[] => {
    const dir = path.join(root, current)
    const entries = fs.readdirSync(dir, { withFileTypes: true })
    const slugs: string[] = []

    for (const entry of entries) {
      if (!entry.isDirectory()) continue
      if (entry.name.startsWith('_') || entry.name === 'pagefind') continue

      const nested = current ? path.join(current, entry.name) : entry.name
      const indexPath = path.join(root, nested, 'index.html')
      if (fs.existsSync(indexPath)) {
        slugs.push(nested)
      }
      slugs.push(...collectDocSlugs(root, nested))
    }

    return slugs
  }

  return collectDocSlugs(docsRoot).map((slug) => ({
    params: { slug },
  }))
}

const docsRoot = path.resolve('public/docs')
const slug = Astro.params.slug ?? ''
const segments = Array.isArray(slug) ? slug : String(slug).split('/').filter(Boolean)
const filePath = path.join(docsRoot, ...segments, 'index.html')
const html = await fs.promises.readFile(filePath, 'utf8')
const reactGrabScripts = [
  '<script src="//unpkg.com/react-grab/dist/index.global.js" crossorigin="anonymous"></script>',
  '<script src="//unpkg.com/@react-grab/claude-code/dist/client.global.js" crossorigin="anonymous"></script>',
].join('')
const renderedHtml = import.meta.env.DEV ? html.replace('</head>', `${reactGrabScripts}</head>`) : html
---
<Fragment set:html={renderedHtml} />
